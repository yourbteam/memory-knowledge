# Remote mode — connects to managed cloud databases
DATA_MODE=remote
ALLOW_REMOTE_WRITES=true
# ALLOW_REMOTE_REBUILDS=false  # set to true only for explicit rebuild operations

# Supabase PostgreSQL (direct connection, port 5432)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres
PG_SSL=true

# Qdrant Cloud
QDRANT_URL=https://[cluster-id].us-east4-0.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=[your-qdrant-api-key]

# Neo4j Aura
NEO4J_URI=neo4j+s://[instance-id].databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=[your-neo4j-password]

# Auth — uses Codex CLI OAuth tokens
AUTH_MODE=codex
CODEX_AUTH_PATH=~/.codex/auth.json

# Azure Key Vault — seeds DB secrets on startup in remote mode
# AZURE_KEYVAULT_NAME=your-vault-name
# KV_PG_SECRET_NAME=db-postgres-url
# KV_QDRANT_SECRET_NAME=db-qdrant-apikey
# KV_NEO4J_SECRET_NAME=db-neo4j-password

# Embedding/completion models
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Server
SERVER_PORT=8000
ENVIRONMENT=production
