# PostgreSQL
DATABASE_URL=postgresql://memoryknowledge:memoryknowledge@localhost:5432/memoryknowledge
PG_POOL_MIN_SIZE=5
PG_POOL_MAX_SIZE=20

# Qdrant
QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# NEO4J_MAX_POOL_SIZE=50

# Auth mode: "api_key" (default) or "codex" (uses Codex CLI OAuth tokens)
AUTH_MODE=api_key
# CODEX_AUTH_PATH=~/.codex/auth.json

# OpenAI (required when AUTH_MODE=api_key, ignored when AUTH_MODE=codex)
OPENAI_API_KEY=sk-your-key-here
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Server
SERVER_PORT=8000
