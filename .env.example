# PostgreSQL (use "postgres" as host when running via docker-compose)
DATABASE_URL=postgresql://memoryknowledge:memoryknowledge@postgres:5432/memoryknowledge
PG_POOL_MIN_SIZE=5
PG_POOL_MAX_SIZE=20
# PG_SSL=false
# PG_COMMAND_TIMEOUT=30

# Qdrant (use "qdrant" as host when running via docker-compose)
QDRANT_URL=http://qdrant:6333
# QDRANT_API_KEY=

# Neo4j (use "neo4j" as host when running via docker-compose)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password
# NEO4J_MAX_POOL_SIZE=50

# Auth — uses Codex CLI OAuth tokens (ChatGPT Pro subscription)
# The server reads tokens from ~/.codex/auth.json (10-day token lifetime)
# Run 'codex auth' to authenticate before starting the server
AUTH_MODE=codex
CODEX_AUTH_PATH=~/.codex/auth.json

# MCP endpoint authentication (set to protect the /mcp endpoint)
# MCP_API_KEY=your-secret-api-key

# Embedding/completion models (used via Codex OAuth token, not API key)
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
# MAX_COMPLETION_TOKENS=4096

# CORS (comma-separated origins, default * for all)
# CORS_ALLOWED_ORIGINS=*

# Server
SERVER_PORT=8000
# LOG_LEVEL=INFO
# ENVIRONMENT=production

# Import size limit (MB)
# MAX_IMPORT_SIZE_MB=50
